{
  "name": "copilotkit-langgraph-template",
  "private": true,
  "scripts": {
    "dev": "turbo run dev --no-cache",
    "dev:app": "turbo run dev --filter='app' --no-cache",
    "dev:agent": "turbo run dev --filter='agent' --no-cache",
    "dev:mcp": "turbo run dev --filter='mcp' --no-cache",
    "build": "turbo run build  --no-cache",
    "start": "cd ./apps/app/out/ && npx serve@latest -l 3000",
    "lint": "turbo run lint",
    "clean": "turbo run clean"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "turbo": "^2.9.5"
  },
  "packageManager": "pnpm@10.33.0",
  "pnpm": {
    "overrides": {
      "esbuild": "^0.27.3"
    }
  }
}